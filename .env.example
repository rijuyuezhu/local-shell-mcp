# Cloudflare Access team domain, usually <team-name>.cloudflareaccess.com
LOCAL_SHELL_MCP_CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com

# Cloudflare Access Application Audience (AUD) tag.
LOCAL_SHELL_MCP_CF_ACCESS_AUDIENCE=your-access-aud-tag

# Optional allowlists. Comma separated.
LOCAL_SHELL_MCP_CF_ACCESS_ALLOWED_EMAILS=you@example.com
LOCAL_SHELL_MCP_CF_ACCESS_ALLOWED_EMAIL_DOMAINS=

# Keep false unless the container is disposable and intentionally fully controlled by ChatGPT.
LOCAL_SHELL_MCP_ALLOW_FULL_CONTAINER=false

# Optional for the cloudflared sidecar profile.
CLOUDFLARE_TUNNEL_TOKEN=
