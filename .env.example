# Docker Compose uses this file as the main container environment via `env_file: .env`.
# Copy it with: cp .env.example .env

# Server.
# Server transport mode: mcp, http, stdio, or both.
LOCAL_SHELL_MCP_MODE=mcp
# Bind host for HTTP/MCP transports.
LOCAL_SHELL_MCP_HOST=0.0.0.0
# Bind port for HTTP/MCP transports.
LOCAL_SHELL_MCP_PORT=8765

# Paths and state.
# Root directory for normal file and command operations.
LOCAL_SHELL_MCP_WORKSPACE_ROOT=/workspace
# Directory for runtime state such as audit logs and temporary files.
LOCAL_SHELL_MCP_STATE_DIR=/workspace/.local-shell-mcp
# Path to the JSONL audit log.
LOCAL_SHELL_MCP_AUDIT_LOG_PATH=/workspace/.local-shell-mcp/audit.jsonl

# Authentication and OAuth.
# Authentication mode: oauth or none. Do not expose public services with none.
LOCAL_SHELL_MCP_AUTH_MODE=oauth
# Allow localhost requests without bearer authentication.
LOCAL_SHELL_MCP_AUTH_BYPASS_LOCALHOST=true
# Require authentication for MCP initialize/list-tools discovery calls.
LOCAL_SHELL_MCP_REQUIRE_AUTH_FOR_MCP_DISCOVERY=false
# Public HTTPS origin used in OAuth metadata and callbacks.
LOCAL_SHELL_MCP_PUBLIC_BASE_URL=
# Override OAuth issuer metadata; defaults to public_base_url when unset.
LOCAL_SHELL_MCP_OAUTH_ISSUER=
# Override OAuth resource metadata; defaults to public_base_url when unset.
LOCAL_SHELL_MCP_OAUTH_RESOURCE=
# PIN required to approve OAuth authorization.
LOCAL_SHELL_MCP_OAUTH_ADMIN_PIN=
# Secret used to sign OAuth bearer tokens; set a strong random value.
LOCAL_SHELL_MCP_OAUTH_JWT_SECRET=dev-change-me
# Bearer token lifetime in seconds; 0 means no expiry.
LOCAL_SHELL_MCP_OAUTH_ACCESS_TOKEN_TTL_S=0
# OAuth authorization-code lifetime in seconds.
LOCAL_SHELL_MCP_OAUTH_CODE_TTL_S=300

# Safety and resource limits.
# Disable built-in workspace and command restrictions; use only in disposable containers or VMs.
LOCAL_SHELL_MCP_ALLOW_FULL_CONTAINER=false
# Allow network-capable operations.
LOCAL_SHELL_MCP_ALLOW_NETWORK=true
# Default shell command timeout in seconds.
LOCAL_SHELL_MCP_DEFAULT_TIMEOUT_S=60
# Maximum shell command timeout in seconds.
LOCAL_SHELL_MCP_MAX_TIMEOUT_S=3600
# Command output truncation limit in bytes.
LOCAL_SHELL_MCP_MAX_OUTPUT_BYTES=200000
# Per-file read limit in bytes.
LOCAL_SHELL_MCP_MAX_FILE_READ_BYTES=512000
# Per-file write/edit limit in bytes.
LOCAL_SHELL_MCP_MAX_FILE_WRITE_BYTES=5000000
# Maximum grep result count.
LOCAL_SHELL_MCP_MAX_GREP_RESULTS=200
# Maximum listed directory entries.
LOCAL_SHELL_MCP_MAX_DIRECTORY_ENTRIES=5000
# Maximum glob search results.
LOCAL_SHELL_MCP_MAX_GLOB_RESULTS=5000
# Maximum tree-view entries.
LOCAL_SHELL_MCP_MAX_TREE_ENTRIES=5000
# Maximum files read by a multi-file read operation.
LOCAL_SHELL_MCP_MAX_READ_MANY_FILES=100
# Combined byte limit for multi-file reads.
LOCAL_SHELL_MCP_MAX_READ_MANY_TOTAL_BYTES=5000000
# Todo-list item limit.
LOCAL_SHELL_MCP_MAX_TODOS=1000
# Todo-list serialized byte limit.
LOCAL_SHELL_MCP_MAX_TODO_BYTES=1000000
# Audit-tail response byte limit.
LOCAL_SHELL_MCP_MAX_AUDIT_TAIL_BYTES=1000000
# Audit-log rotation threshold in bytes.
LOCAL_SHELL_MCP_MAX_AUDIT_LOG_BYTES=20000000
# Temporary-file count limit.
LOCAL_SHELL_MCP_MAX_TMP_FILES=500
# Temporary-file byte limit.
LOCAL_SHELL_MCP_MAX_TMP_BYTES=50000000
# Concurrent command limit.
LOCAL_SHELL_MCP_MAX_CONCURRENT_COMMANDS=4
# Persistent shell session limit.
LOCAL_SHELL_MCP_MAX_TMUX_SESSIONS=16
# Comma-separated command denylist in env/CLI, or a YAML list in config files. Cleared when
# full-container mode is enabled.
LOCAL_SHELL_MCP_COMMAND_DENYLIST=docker.sock,/var/run/docker.sock,mkfs,mount ,umount ,shutdown,reboot,systemctl ,iptables,nft 
# Comma-separated path denylist in env/CLI, or a YAML list in config files. Cleared when
# full-container mode is enabled.
LOCAL_SHELL_MCP_PATH_DENYLIST=.ssh/id_rsa,.ssh/id_ed25519,.env,secrets,credentials,.git/config

# Remote workers.
# Enable remote worker routes and MCP tools.
LOCAL_SHELL_MCP_REMOTE_ENABLED=true
# One-time remote worker invite lifetime in seconds.
LOCAL_SHELL_MCP_REMOTE_INVITE_TTL_S=600
# Remote worker long-poll heartbeat timeout in seconds.
LOCAL_SHELL_MCP_REMOTE_POLL_TIMEOUT_S=25
# Control-side remote job result timeout in seconds.
LOCAL_SHELL_MCP_REMOTE_JOB_TIMEOUT_S=3600

# Agent capability bridge.
# Enable agent capability bridge tools.
LOCAL_SHELL_MCP_AGENT_BRIDGE_ENABLED=true
# Read-only capability config directory.
LOCAL_SHELL_MCP_AGENT_CONFIG_DIR=/home/agent/local-shell-mcp-config
# Agent MCP server probe timeout in seconds.
LOCAL_SHELL_MCP_AGENT_MCP_PROBE_TIMEOUT_S=5
# Agent MCP tool-call timeout in seconds.
LOCAL_SHELL_MCP_AGENT_MCP_CALL_TIMEOUT_S=60
# Register dynamic MCP bridge tools.
LOCAL_SHELL_MCP_AGENT_DYNAMIC_MCP_TOOLS=true
# Register dynamic skill bridge tools.
LOCAL_SHELL_MCP_AGENT_DYNAMIC_SKILL_TOOLS=true

# Tool executables.
# Shell executable used for shell commands.
LOCAL_SHELL_MCP_SHELL_EXECUTABLE=/bin/bash
# tmux executable.
LOCAL_SHELL_MCP_TMUX_BIN=tmux
# ripgrep executable.
LOCAL_SHELL_MCP_RG_BIN=rg
# Git executable.
LOCAL_SHELL_MCP_GIT_BIN=git
# Python executable.
LOCAL_SHELL_MCP_PYTHON_BIN=python3

# Docker entrypoint settings. These are read before local-shell-mcp starts.
# Run the Dockerized MCP server itself as root. Prefer explicit sudo inside commands instead.
DOCKER_RUN_AS_ROOT=false
# Persist GitHub CLI, Git HTTPS credentials, GitCode credentials, SSH keys, .netrc, and GPG state
# across container rebuilds.
DOCKER_PERSISTENT_CREDENTIALS=true
# Root directory for persisted credentials. The Docker Compose example stores it in the
# local-shell-mcp-credentials volume.
DOCKER_CREDENTIALS_DIR=/persist/credentials
# chown the mounted workspace to the agent user before starting the server.
DOCKER_CHOWN_WORKSPACE=true

# Optional sidecar settings.
# Optional token for the cloudflared tunnel sidecar profile. This uses Cloudflare Tunnel only, not
# Cloudflare Access.
CLOUDFLARE_TUNNEL_TOKEN=
